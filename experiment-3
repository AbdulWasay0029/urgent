<!DOCTYPE html>
<html>
<head>
<title>Register</title>

<script>
function validate(){
 let name = frm.fname.value;
 let phone = frm.phone.value;
 let mail = frm.mailid.value;
 let pwd = frm.pwd.value;

 if(!/^[A-Za-z]+$/.test(name)){
  alert("Invalid name"); return false;
 }

 if(!/^\d{10}$/.test(phone)){
  alert("Invalid phone"); return false;
 }

 if(!/^[^ ]+@[^ ]+\.[^ ]+$/.test(mail)){
  alert("Invalid email"); return false;
 }

 if(pwd.length > 8){
  alert("Max 8 chars"); return false;
 }

 localStorage.setItem("username", frm.uname.value);
 localStorage.setItem("password", frm.pwd.value);

 return true;
}
</script>

</head>

<body>
<h2>Register</h2>

<form name="frm" action="success.html" onsubmit="return validate()">

 Name: <input name="fname" required><br>
 Phone: <input name="phone" required><br>
 Email: <input name="mailid" required><br>
 Username: <input name="uname" required><br>
 Password: <input name="pwd" required><br>

 <input type="submit" value="Register">
 <a href="login.html">Login</a>

</form>

</body>
</html>
